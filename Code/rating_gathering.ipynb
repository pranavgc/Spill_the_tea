   "source": [
    "%%time\n",
    "def get_google_place_data(name, postcode):\n",
    "    \"\"\"\n",
    "    Fetches the ratings, price level, and reviews for a given place from Google Places API.\n",
    "    \"\"\"\n",
    "    # Step A: Use Text Search to find the Place ID\n",
    "    query = f\"{name} {postcode}\"\n",
    "    search_url = f\"https://maps.googleapis.com/maps/api/place/textsearch/json?query={query}&key={API_KEY}\"\n",
    "    \n",
    "    try:\n",
    "        search_response = requests.get(search_url).json()\n",
    "        \n",
    "        if search_response.get('status') == 'OK' and len(search_response.get('results', [])) > 0:\n",
    "            place_id = search_response['results'][0]['place_id']\n",
    "            \n",
    "            # Step B: Use Place Details to get the specific required fields\n",
    "            details_url = f\"https://maps.googleapis.com/maps/api/place/details/json?place_id={place_id}&fields=rating,price_level,reviews&key={API_KEY}\"\n",
    "            details_response = requests.get(details_url).json()\n",
    "            \n",
    "            if details_response.get('status') == 'OK':\n",
    "                result = details_response.get('result', {})\n",
    "                \n",
    "                # Extract Overall Rating & Price Level\n",
    "                overall_rating = result.get('rating', 'N/A')\n",
    "                price_level = result.get('price_level', 'N/A')\n",
    "                \n",
    "                # Extract Individual Reviews and Review Ratings\n",
    "                reviews_list = result.get('reviews', [])\n",
    "                reviews_texts = []\n",
    "                review_ratings = []\n",
    "                \n",
    "                for r in reviews_list:\n",
    "                    # Clean up newline characters so it fits neatly in a CSV cell\n",
    "                    text = r.get('text', '').replace('\\n', ' ')\n",
    "                    rating = str(r.get('rating', ''))\n",
    "                    \n",
    "                    reviews_texts.append(text)\n",
    "                    review_ratings.append(rating)\n",
    "                \n",
    "                # Join the top 5 reviews (Google provides up to 5 by default) into a single string separated by ' | '\n",
    "                reviews_combined = \" | \".join(reviews_texts) if reviews_texts else \"N/A\"\n",
    "                review_ratings_combined = \" | \".join(review_ratings) if review_ratings else \"N/A\"\n",
    "                \n",
    "                return overall_rating, price_level, reviews_combined, review_ratings_combined\n",
    "                \n",
    "    except Exception as e:\n",
    "        print(f\"Error fetching data for {name}: {e}\")\n",
    "        \n",
    "    # Return defaults if nothing is found or an error occurs\n",
    "    return \"N/A\", \"N/A\", \"N/A\", \"N/A\"\n",
    "\n",
    "# Prepare lists to hold the new column data\n",
    "overall_ratings = []\n",
    "price_levels = []\n",
    "all_reviews = []\n",
    "all_review_ratings = []\n",
    "\n",
    "print(\"Starting to fetch data from Google Places API...\")\n",
    "\n",
    "# 3. Iterate over the DataFrame\n",
    "# Based on your CSV, Column B is 'CompanyName' and Column I is 'RegAddress.PostCode'\n",
    "for index, row in df.iterrows():\n",
    "    name = row['BusinessName']\n",
    "    postcode = row['PostCode']\n",
    "    \n",
    "    # Handle blank/missing values\n",
    "    if pd.isna(name) or pd.isna(postcode):\n",
    "        overall_ratings.append(\"N/A\")\n",
    "        price_levels.append(\"N/A\")\n",
    "        all_reviews.append(\"N/A\")\n",
    "        all_review_ratings.append(\"N/A\")\n",
    "        continue\n",
    "        \n",
    "    print(f\"Fetching: {name} ({postcode})...\")\n",
    "    \n",
    "    # Fetch details\n",
    "    r_rating, p_level, r_texts, r_individual_ratings = get_google_place_data(name, postcode)\n",
    "    \n",
    "    overall_ratings.append(r_rating)\n",
    "    price_levels.append(p_level)\n",
    "    all_reviews.append(r_texts)\n",
    "    all_review_ratings.append(r_individual_ratings)\n",
    "    \n",
    "    # Sleep to ensure we don't hit API rate limits too quickly\n",
    "    time.sleep(0.2) \n",
    "\n",
    "# 4. Add the fetched lists as new columns in the DataFrame\n",
    "df['Google_Overall_Rating'] = overall_ratings\n",
    "df['Google_Price_Level'] = price_levels\n",
    "df['Google_Review_Texts'] = all_reviews\n",
    "df['Google_Individual_Review_Ratings'] = all_review_ratings\n",
    "\n",
    "# 5. Save the updated dataset to a new CSV file\n",
    "output_file = \"Quer_file_output_03_06_26.xlsx\"\n",
    "df.to_excel(output_file, index=False)\n",
    "\n",
    "print(f\"\\nSuccessfully finished processing. Data saved to '{output_file}'\")"
   ]
